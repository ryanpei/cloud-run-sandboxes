# ==========================================
# SECURE SERVERLESS SANDBOX: .gitignore
# ==========================================

# Dependency directories
node_modules/
jspm_packages/
web_stage/

# Compiled JavaScript outputs
dist/
build/
out/

# TypeScript/JavaScript caches
.tscache/
.tsbuildinfo
.eslintcache
.parcel-cache

# Local secret configurations & private keys
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
*.pem
*.key
credentials.json
service-account-key.json

# Log outputs and run caches
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*
*.log
logs/
run/

# Workstation & IDE-specific files
.DS_Store
.idea/
.vscode/
*.suo
*.ntvs*
*.njsproj
*.sln
*.swp
*.swo

# GCloud / Build artifacts
.gcloud/
.cloudbuild/
gsutil/
tarball.tgz
source.tgz
tgz/
